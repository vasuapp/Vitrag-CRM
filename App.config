<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <connectionStrings>
    <!-- Overridden at runtime by DATABASE_URL environment variable -->
    <add name="DefaultConnection" connectionString="Host=127.0.0.1;Port=5432;Database=postgres;Username=postgres;Password=postgres" providerName="Npgsql" />
  </connectionStrings>
  <appSettings>
    <add key="PORT" value="5001" />
    <add key="SESSION_SECRET" value="super_secret_fallback_key_for_vitrag_crm" />
  </appSettings>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
</configuration>
