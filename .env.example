# Vitrag CRM - Environment Configuration Template
# Copy this file to .env and fill in the values for the target system.

# Server Port
PORT=5001

# Express Session Cookie Secret (use a random string in production)
SESSION_SECRET=vitrag-crm-subh-homes-secret-2026

# Default Security Code for specific features
ADMIN_PIN=123456

# PostgreSQL Connection String (required)
# Format for Local: postgresql://username:password@localhost:5432/dbname
# Format for Railway: postgresql://postgres:password@host.railway.internal:5432/railway
DATABASE_URL=

# Outbound Mail configurations (Optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@subhhomes.com
REPORT_EMAIL=
